generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String   @unique
  name      String?
  role      String   // "STUDENT" | "EDUCATOR" | "ADMIN"
  passwordHash String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Educator fields
  educatorSlug String? @unique
  kycStatus    String? // "PENDING" | "APPROVED" | "REJECTED"
  // KYC document fields
  kycCollege        String?
  kycGraduationYear Int?
  kycLinkedin       String?
  kycDocumentUrl    String? // Cloudinary URL

  // Relations
  bookingsAsStudent Booking[] @relation("StudentBookings")
  bookingsAsEducator Booking[] @relation("EducatorBookings")
  services           Service[]
  availabilityRules  AvailabilityRule[]
  questions          Question[]
}

model Service {
  id              String   @id @default(cuid())
  educatorId      String
  educator        User     @relation(fields: [educatorId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  durationMinutes Int
  price           Float
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings Booking[]

  @@index([educatorId])
}

model AvailabilityRule {
  id              String   @id @default(cuid())
  educatorId      String
  educator        User     @relation(fields: [educatorId], references: [id], onDelete: Cascade)
  startDate       DateTime
  endDate         DateTime
  daysOfWeek      String   // JSON array of numbers [0,1,2,3,4,5,6]
  specificDates   String?  // JSON array of ISO date strings
  startTime       String   // HH:mm format
  durationMinutes Int
  price           Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([educatorId])
}

model AvailabilitySlot {
  id        String   @id @default(cuid())
  educatorId String
  startTime DateTime
  endTime   DateTime
  isBooked  Boolean  @default(false)
  price     Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@index([educatorId])
  @@index([startTime])
  @@index([isBooked])
}

model Booking {
  id          String   @id @default(cuid())
  studentId   String
  student     User     @relation("StudentBookings", fields: [studentId], references: [id], onDelete: Cascade)
  educatorId  String
  educator    User     @relation("EducatorBookings", fields: [educatorId], references: [id], onDelete: Cascade)
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  slotId      String
  slot        AvailabilitySlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  status      String   // "UPCOMING" | "COMPLETED" | "CANCELLED"
  // Payment fields
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  paymentStatus     String?  // "PENDING" | "COMPLETED" | "FAILED"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([studentId])
  @@index([educatorId])
  @@index([status])
}

model TrialCall {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}

model Question {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  message     String
  educatorId  String
  educator    User     @relation(fields: [educatorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
  @@index([educatorId])
}

model Otp {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}

model College {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  shortName       String?
  location        String
  heroImageUrl    String?
  hero            String?  // JSON: {tagline, description, badges[], primaryAction, secondaryAction}
  about           String?  // JSON: string[]
  courses         String?  // JSON: CourseDetail[]
  admission       String?  // JSON: {title, subtitle, steps[]}
  recruiters      String?  // JSON: {title, logos[], cutoff[], placements[]}
  reviews         String?  // JSON: ReviewDetail[]
  faqs            String?  // JSON: FaqDetail[]
  collegeType     String?  // "IIT"|"NIT"|"IIM"|"NID"|"Medical"|"Law"|etc.
  collegeTier     String?  // "Tier 1"|"Tier 2"|"Tier 3"
  rating          Float?
  metaTitle       String?
  metaDescription String?
  published       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  alumni          Alumni[]

  @@index([slug])
  @@index([published])
  @@index([collegeType])
}

model Alumni {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  headline        String?
  bio             String?
  course          String?
  graduationYear  Int?
  currentCompany  String?
  currentJobRole  String?
  jobLocation     String?
  location        String?
  mobileNumber    String?
  mail            String?
  profileImageUrl String?
  heroImageUrl    String?
  isBookable      Boolean  @default(false)
  isFeatured      Boolean  @default(false)
  heroTagline     String?
  heroSummary     String?  // JSON: string[]
  overview        String?  // JSON: string[]
  availability    String?
  stats           String?  // JSON: {label, value}[]
  focusAreas      String?  // JSON: {title, description}[]
  sessions        String?  // JSON: SessionOffering[]
  highlights      String?  // JSON: string[]
  resources       String?  // JSON: {label, href}[]
  reviews         String?  // JSON: AlumniReview[]
  featuredQuote   String?
  bookingUrl      String?
  questionUrl     String?
  published       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  collegeId       String?
  college         College?  @relation(fields: [collegeId], references: [id])

  @@index([slug])
  @@index([collegeId])
  @@index([published])
  @@index([isFeatured])
}
